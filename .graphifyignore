# .graphifyignore — delta sobre as exclusões built-in do graphify.
# Built-ins já cobrem: node_modules, venv/.venv/env, .git, __pycache__, dist, build,
# target, out, coverage, .next, .nuxt, .idea, .cache, .pytest_cache, .mypy_cache,
# graphify-out, .graphify, .worktrees, site-packages, lockfiles e arquivos secret-like.
# Aqui só o que falta no workspace Personal.

# git worktrees top-level (JARVIS/worktrees/ — RULES #19a; built-in só pega .worktrees)
worktrees/

# deps/artefatos não cobertos
vendor/
storage/
logs/
tmp/

# bancos e logs
*.sqlite
*.sqlite3
*.db
*.log

# segredos/certs (defesa extra — graphify já pula secret-like; RULES proíbe tocar)
.env
.env.*
*.pem
*.key
*.crt

# mídia/arquivos pesados (descomente exceções se precisar grafar algum)
*.mp4
*.mov
*.mkv
*.mp3
*.wav
*.zip
*.tar
*.gz
